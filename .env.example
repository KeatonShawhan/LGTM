# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub App server (required when running the webhook server)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Optional — model override for reviews (default: claude-sonnet-4-6)
REVIEW_MODEL=claude-sonnet-4-6

# Optional — required only for CLI reviews of private GitHub repositories
GITHUB_TOKEN=your_github_personal_access_token_here

# Optional — enables LangSmith tracing for observability
LANGSMITH_API_KEY=your_langsmith_api_key_here

# CLI convenience variables (used by main.py only)
REPO_URL=https://github.com/owner/repo
BRANCH=main
