.env
sandbox
sandbox/*
# Python temp files
__pycache__/
*.py[cod]
*/__pycache__/
**/__pycache__

# Cython artifacts
*.c
*.cpp
*.so
*.pyd
build/
cython_debug/

# Cache directory (repositories and metadata)
cache/repos/
cache/repos/*
cache/file_summaries/
cache/file_summaries/*

# Benchmark results (regenerated per run)
benchmarks/results/*.json

# Benchmark fixture repo (generated by setup script)
benchmarks/fixture_repo/

.claude/